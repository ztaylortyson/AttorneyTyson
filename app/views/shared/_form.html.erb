

<%= form_with(model: @intake, url: new_intake_path) do |form| %>

  <% if intake.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(intake.errors.count, "error") %> prohibited this client from being saved:</h2>

      <ul>
        <% intake.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>


